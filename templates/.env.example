# =============================================================
# TEMPLATE CREDENTIALS MINIO — À COPIER EN .env À LA RACINE
# =============================================================
# 1. Copier ce fichier : cp .env.example .env
# 2. Remplir les valeurs
# 3. Ne JAMAIS commiter le fichier .env (ajouter dans .gitignore)

# --- ENDPOINT MINIO ---
# Choisir UNE des deux options selon l'environnement :

# Option A : Depuis votre machine locale (hors cluster)
MINIO_ENDPOINT=http://192.168.1.230:30137

# Option B : Depuis JupyterHub (dans le cluster Kubernetes)
# MINIO_ENDPOINT=http://minio.mon-namespace.svc.cluster.local:80

# --- CREDENTIALS ---
MINIO_ACCESS_KEY=datalab-team
MINIO_SECRET_KEY=minio-datalabteam123

# --- NESSIE (uniquement pour les jobs Spark) ---
# Option A : Local
NESSIE_URI=http://192.168.1.230:30604/api/v1

# Option B : Cluster
# NESSIE_URI=http://nessie.trino.svc.cluster.local:19120/api/v1

# --- BUCKETS ---
MINIO_BUCKET_STAGING=staging
MINIO_BUCKET_BRONZE=bronze
MINIO_BUCKET_SILVER=silver
MINIO_BUCKET_GOLD=gold
